---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio of Farhan Ahmed, a Backend Developer and AWS Cloud Engineer specializing in Java, Spring Boot, and cloud infrastructure." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/F.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10b981" />
  </head>
  <body>
    <div class="min-h-screen text-white relative overflow-hidden bg-[#0a0a0a]">
      <div class="absolute inset-0 z-0 bg-blend-overlay opacity-18">
        <img
          src="/images/animated-bg-2.gif"
          alt="Animated Background"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 relative z-10">
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>