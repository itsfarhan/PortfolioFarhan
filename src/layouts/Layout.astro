---
import Navigation from "../components/Navigation";
import Footer from "../components/Footer";
import BackgroundSettings from "../components/BackgroundSettings";
import AudioControl from "../components/AudioControl";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio of Farhan Ahmed, a Backend Developer and AWS Cloud Engineer specializing in Java, Spring Boot, and cloud infrastructure." } = Astro.props;

// Default background option
const backgroundOption = "2";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/F.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10b981" />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen text-white relative overflow-hidden" style="background-color: var(--light-black-950);">
      <div class="absolute inset-0 z-0 bg-blend-overlay" style="opacity: 0.18;">
        <img
          src={`/images/animated-bg-${backgroundOption}.gif`}
          alt="Animated Background"
          class="w-full h-full object-cover"
        />
      </div>
      
      <!-- Scroll to top button -->
      <button
        class="fixed top-4 right-4 p-2 rounded-full text-emerald-400 hover:text-emerald-300 transition-colors z-20"
        style="background-color: var(--light-black-800);"
        id="scroll-top"
      >
        ↑
      </button>

      <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 relative z-10">
        <slot />
        <Footer />
      </div>
    </div>

    <!-- Navigation at the bottom -->
    <div class="fixed bottom-0 left-0 right-0 z-50">
      <Navigation client:load />
    </div>

    <!-- Background settings component -->
    <BackgroundSettings currentBg={backgroundOption} client:load />
    
    <!-- Audio control component -->
    <AudioControl client:load />

    <script>
      // Scroll to top functionality
      document.getElementById('scroll-top')?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>