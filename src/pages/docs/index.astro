---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Get all docs entries
const allDocs = await getCollection("docs", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Get unique categories
const categories = [...new Set(allDocs.map(doc => doc.data.category))].sort();

// Group docs by category
const docsByCategory = categories.map(category => {
  const docs = allDocs
    .filter(doc => doc.data.category === category)
    .sort((a, b) => a.data.order - b.data.order);
  
  return {
    category,
    docs
  };
});
---

<Layout title="Farhan Ahmed | Documentation">
  <div class="min-h-screen pt-8 pb-32">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold text-white mb-4 animate-fade-in relative inline-block">
        Documentation
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-emerald-400 to-transparent"></span>
      </h2>
      <p class="text-white/70 max-w-2xl mx-auto animate-fade-in text-sm">
        My personal notes, guides, and reference materials
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="md:col-span-1">
        <div 
          class="sticky top-24 rounded-lg glass-effect hover-card animate-fade-in"
        >
          <div class="p-5">
            <h3 class="text-lg font-medium text-white mb-4 pb-2 border-b border-white/10 relative">
              Categories
              <span 
                class="absolute bottom-0 left-0 h-[2px] bg-emerald-400 rounded-full"
                style={{ width: '25%' }}
              ></span>
            </h3>
            
            <nav class="space-y-1">
              {categories.map(category => (
                <a 
                  href={`#${category.toLowerCase().replace(/\s+/g, '-')}`}
                  class="block py-1.5 px-3 rounded text-sm hover:bg-emerald-500/5 text-white/80 hover:text-emerald-400 transition-colors"
                >
                  {category}
                </a>
              ))}
            </nav>
            
            <div class="mt-6 pt-4 border-t border-white/10">
              <a 
                href="/docs/create"
                class="inline-flex items-center gap-2 text-emerald-400 text-sm hover:text-emerald-300 transition-colors group"
              >
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="h-4 w-4" 
                  viewBox="0 0 24 24" 
                  fill="none" 
                  stroke="currentColor" 
                  stroke-width="2" 
                  stroke-linecap="round" 
                  stroke-linejoin="round"
                >
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                <span class="group-hover:underline">Add New Document</span>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="md:col-span-3">
        {docsByCategory.map(({ category, docs }, categoryIndex) => (
          <section 
            id={category.toLowerCase().replace(/\s+/g, '-')}
            class="mb-10 scroll-mt-24"
            style={{ 
              opacity: 0,
              animation: `fadeIn 0.5s ${categoryIndex * 0.15}s forwards`
            }}
          >
            <h3 class="text-xl font-medium text-white mb-4 relative inline-block">
              {category}
              <span class="absolute bottom-0 left-0 w-full h-[1px] bg-emerald-400 rounded-full"></span>
            </h3>
            
            <div class="grid grid-cols-1 gap-4">
              {docs.map((doc, docIndex) => (
                <a 
                  href={`/docs/${doc.slug}`}
                  class="rounded-lg glass-effect hover-card p-4"
                  style={{ 
                    opacity: 0,
                    animation: `fadeIn 0.5s ${categoryIndex * 0.15 + docIndex * 0.1}s forwards`
                  }}
                >
                  <div class="flex items-center mb-2">
                    <div class="w-1 h-8 bg-emerald-400/50 mr-3 rounded transition-all duration-300 group-hover:h-12"></div>
                    <h4 class="text-lg font-medium text-white group-hover:text-emerald-400 transition-colors duration-300">
                      {doc.data.title}
                    </h4>
                  </div>
                  
                  <p class="text-white/70 text-sm mb-3 line-clamp-2">{doc.data.description}</p>
                  
                  <div class="flex justify-between items-center">
                    <div class="flex flex-wrap gap-2">
                      {doc.data.tags.slice(0, 3).map((tag) => (
                        <span 
                          class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                          style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
                        >
                          {tag}
                        </span>
                      ))}
                      {doc.data.tags.length > 3 && (
                        <span 
                          class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                          style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
                        >
                          +{doc.data.tags.length - 3}
                        </span>
                      )}
                    </div>
                    
                    <div class="flex items-center text-emerald-400 text-sm">
                      Read
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4 ml-1"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
        
        {docsByCategory.length === 0 && (
          <div class="text-center p-10 rounded-lg glass-effect animate-fade-in">
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              class="h-16 w-16 mx-auto text-emerald-500/30 mb-4" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="1" 
              stroke-linecap="round" 
              stroke-linejoin="round"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            <p class="text-white/70 mb-2">No documentation available yet.</p>
            <p class="text-emerald-400 text-sm mb-4">Start by adding your first document.</p>
            <a 
              href="/docs/create" 
              class="inline-block px-4 py-2 bg-emerald-600 text-white text-sm rounded-md hover:bg-emerald-700 transition-all duration-300"
            >
              Create New Document
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>