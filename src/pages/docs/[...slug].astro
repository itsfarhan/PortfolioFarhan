---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Generate static paths for all docs
export async function getStaticPaths() {
  const docsEntries = await getCollection("docs");
  return docsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the doc for this page
const { entry } = Astro.props;
const { Content } = await entry.render();

// Format date
const formattedDate = format(entry.data.pubDate, "MMMM d, yyyy");
const formattedUpdateDate = entry.data.updatedDate ? format(entry.data.updatedDate, "MMMM d, yyyy") : null;

// Get all docs in the same category for sidebar navigation
const allDocs = await getCollection("docs", ({ data }) => {
  return data.category === entry.data.category;
});

// Sort by order
const sidebarDocs = allDocs.sort((a, b) => a.data.order - b.data.order);

// Get next and previous docs
const currentIndex = sidebarDocs.findIndex(doc => doc.slug === entry.slug);
const previousDoc = currentIndex > 0 ? sidebarDocs[currentIndex - 1] : null;
const nextDoc = currentIndex < sidebarDocs.length - 1 ? sidebarDocs[currentIndex + 1] : null;
---

<Layout title={`${entry.data.title} | Documentation | Farhan Ahmed`}>
  <div class="min-h-screen pt-8 pb-32">
    <div class="mb-8 animate-fade-in">
      <a 
        href="/docs" 
        class="inline-flex items-center text-emerald-400 hover:text-emerald-300 text-sm group transition-colors"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="h-4 w-4 mr-1 transition-transform group-hover:-translate-x-1" 
          viewBox="0 0 20 20" 
          fill="currentColor"
        >
          <path 
            fill-rule="evenodd" 
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" 
            clip-rule="evenodd"
          />
        </svg>
        <span class="relative">
          Back to Documentation
        </span>
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
      <!-- Sidebar -->
      <div class="md:col-span-1">
        <div 
          class="sticky top-24 rounded-lg glass-effect hover-card animate-fade-in"
        >
          <div class="p-4">
            <h3 class="text-lg font-medium text-white mb-4 pb-2 border-b border-white/10 relative">
              {entry.data.category}
              <span 
                class="absolute bottom-0 left-0 h-[2px] bg-emerald-400 rounded-full"
                style={{ width: '25%' }}
              ></span>
            </h3>
            
            <nav class="space-y-1">
              {sidebarDocs.map(doc => (
                <a 
                  href={`/docs/${doc.slug}`}
                  class={`block py-1.5 px-3 rounded text-sm transition-colors ${
                    doc.slug === entry.slug 
                      ? 'bg-emerald-500/10 text-emerald-400 font-medium' 
                      : 'hover:bg-emerald-500/5 text-white/80 hover:text-emerald-400'
                  }`}
                >
                  {doc.data.title}
                </a>
              ))}
            </nav>
            
            <div class="mt-6 pt-4 border-t border-white/10">
              <a 
                href="/docs"
                class="inline-flex items-center gap-1.5 text-emerald-400 text-sm hover:text-emerald-300 transition-colors group"
              >
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="h-4 w-4" 
                  viewBox="0 0 24 24" 
                  fill="none" 
                  stroke="currentColor" 
                  stroke-width="2" 
                  stroke-linecap="round" 
                  stroke-linejoin="round"
                >
                  <line x1="19" y1="12" x2="5" y2="12"></line>
                  <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                <span class="group-hover:underline">All Documents</span>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Main Content -->
      <div class="md:col-span-4">
        <div class="mb-6">
          <div class="flex flex-wrap items-center gap-2 text-xs text-emerald-400 mb-4">
            <a href="/docs" class="hover:underline">Docs</a>
            <span class="text-white/40">/</span>
            <a href={`/docs#${entry.data.category.toLowerCase().replace(/\s+/g, '-')}`} class="hover:underline">
              {entry.data.category}
            </a>
            <span class="text-white/40">/</span>
            <span class="text-white/80">{entry.data.title}</span>
          </div>
          
          <h1 class="text-2xl md:text-3xl font-bold text-white mb-4">{entry.data.title}</h1>
          
          <div class="flex flex-wrap items-center gap-4 mb-6 text-xs text-white/60">
            <div class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 text-emerald-400/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {formattedDate}
            </div>
            
            {formattedUpdateDate && (
              <div class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 text-emerald-400/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Updated: {formattedUpdateDate}
              </div>
            )}
            
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <span 
                  class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                  style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
                >
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>
        
        {entry.data.heroImage && (
          <div class="relative mb-8 rounded-lg overflow-hidden shadow-sm animate-fade-in">
            <img
              src={entry.data.heroImage}
              alt={entry.data.title}
              class="w-full h-48 md:h-56 object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/50"></div>
          </div>
        )}
        
        <div 
          class="docs-content prose prose-lg prose-invert prose-emerald max-w-none rounded-lg glass-effect animate-fade-in p-6"
        >
          <Content />
        </div>
        
        <!-- Navigation between docs -->
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
          {previousDoc && (
            <a 
              href={`/docs/${previousDoc.slug}`}
              class="p-3 rounded-lg glass-effect transition-all duration-300 hover:translate-x-[-2px] group flex items-start"
            >
              <div class="mr-auto">
                <div class="flex items-center text-emerald-400 mb-1 text-sm">
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-4 w-4 mr-1 transition-transform duration-300 group-hover:translate-x-[-2px]" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                  </svg>
                  Previous
                </div>
                <p class="text-white/90 text-sm">{previousDoc.data.title}</p>
              </div>
            </a>
          )}
          
          {nextDoc && (
            <a 
              href={`/docs/${nextDoc.slug}`}
              class="p-3 rounded-lg glass-effect transition-all duration-300 hover:translate-x-[2px] group flex md:ml-auto text-right items-start"
            >
              <div class="ml-auto">
                <div class="flex items-center justify-end text-emerald-400 mb-1 text-sm">
                  Next
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-4 w-4 ml-1 transition-transform duration-300 group-hover:translate-x-[2px]" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
                <p class="text-white/90 text-sm">{nextDoc.data.title}</p>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>