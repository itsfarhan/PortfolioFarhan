---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the blog post for this page
const { entry } = Astro.props;
const { Content } = await entry.render();

// Format date
const formattedDate = format(entry.data.pubDate, "MMMM d, yyyy");
---

<Layout title={`${entry.data.title} | Farhan Ahmed`}>
  <article class="min-h-screen pb-32">
    <div class="mb-10">
      <a 
        href="/blog" 
        class="inline-flex items-center text-emerald-400 hover:text-emerald-500 mb-8 group transition-colors"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="h-5 w-5 mr-2 transition-transform group-hover:-translate-x-1" 
          viewBox="0 0 20 20" 
          fill="currentColor"
        >
          <path 
            fill-rule="evenodd" 
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" 
            clip-rule="evenodd"
          />
        </svg>
        Back to Blog
      </a>
      
      {entry.data.heroImage && (
        <div class="overflow-hidden rounded-xl mb-8 animate-fade-in">
          <img
            src={entry.data.heroImage}
            alt={entry.data.title}
            class="w-full h-72 object-cover rounded-xl hover:scale-105 transition-transform duration-500"
          />
        </div>
      )}
      
      <h1 class="text-4xl font-bold text-white mb-4 animate-fade-in">{entry.data.title}</h1>
      
      <div class="flex items-center gap-4 mb-8 animate-fade-in">
        <p class="text-emerald-400">{formattedDate}</p>
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span 
              class="px-2 py-1 rounded text-xs text-emerald-400 hover:bg-emerald-500/20 hover:text-emerald-300 transition-colors"
              style={{ backgroundColor: "var(--light-black-700)" }}
            >
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
    
    <div 
      class="blog-content prose prose-lg prose-invert prose-emerald mx-auto p-8 rounded-lg glass-effect animate-fade-in hover-card"
      style={{ 
        backgroundColor: "rgba(24, 24, 24, 0.7)",
        borderLeft: '1px solid rgba(16, 185, 129, 0.1)',
        borderTop: '1px solid rgba(16, 185, 129, 0.1)',
      }}
    >
      <Content />
    </div>
  </article>
</Layout>

<style>
  /* Custom styles for blog content */
  .blog-content {
    max-width: 100%;
  }
  
  .blog-content :global(h1) {
    @apply text-3xl font-bold text-white mb-6 relative;
    position: relative;
  }
  
  .blog-content :global(h1)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 100px;
    height: 3px;
    background: linear-gradient(to right, var(--accent-500), transparent);
    border-radius: 3px;
  }
  
  .blog-content :global(h2) {
    @apply text-2xl font-bold text-white mt-8 mb-4 relative;
    position: relative;
  }
  
  .blog-content :global(h2)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 70px;
    height: 2px;
    background: linear-gradient(to right, var(--accent-500), transparent);
    border-radius: 2px;
  }
  
  .blog-content :global(h3) {
    @apply text-xl font-bold text-white mt-6 mb-3;
  }
  
  .blog-content :global(p) {
    @apply text-white mb-4 leading-relaxed;
  }
  
  .blog-content :global(ul),
  .blog-content :global(ol) {
    @apply text-white mb-4 pl-5;
  }
  
  .blog-content :global(li) {
    @apply mb-2 hover:text-emerald-300 transition-colors;
  }
  
  .blog-content :global(a) {
    @apply text-emerald-400 hover:text-emerald-300 underline transition-colors;
  }
  
  .blog-content :global(blockquote) {
    @apply border-l-4 border-emerald-500 pl-4 italic text-gray-300 my-4 bg-emerald-500/5 py-2 rounded-r-lg;
  }
  
  .blog-content :global(code:not(pre code)) {
    @apply bg-gray-800 text-emerald-300 px-1 py-0.5 rounded text-sm;
  }
  
  .blog-content :global(pre) {
    @apply bg-gray-900 p-4 rounded-lg overflow-auto mb-4 border-l-4 border-emerald-500;
  }
  
  .blog-content :global(img) {
    @apply rounded-lg my-6 mx-auto transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in;
  }
  
  .blog-content :global(hr) {
    @apply border-gray-700 my-8;
  }
</style>