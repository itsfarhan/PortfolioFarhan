---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the blog post for this page
const { entry } = Astro.props;
const { Content } = await entry.render();

// Format date
const formattedDate = format(entry.data.pubDate, "MMMM d, yyyy");
---

<Layout title={`${entry.data.title} | Farhan Ahmed`}>
  <article class="min-h-screen pt-8 pb-32">
    <div class="mb-8 animate-fade-in">
      <a 
        href="/blog" 
        class="inline-flex items-center text-emerald-400 hover:text-emerald-300 text-sm group transition-colors"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="h-4 w-4 mr-1 transition-transform group-hover:-translate-x-1" 
          viewBox="0 0 20 20" 
          fill="currentColor"
        >
          <path 
            fill-rule="evenodd" 
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" 
            clip-rule="evenodd"
          />
        </svg>
        <span class="relative">
          Back to Blog
        </span>
      </a>
    </div>
    
    <div class="max-w-3xl mx-auto">
      {entry.data.heroImage && (
        <div class="relative mb-8 rounded-lg overflow-hidden shadow-sm animate-fade-in">
          <img
            src={entry.data.heroImage}
            alt={entry.data.title}
            class="w-full h-56 md:h-64 object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/60"></div>
        </div>
      )}
      
      <div class="mb-8 animate-fade-in">
        <h1 class="text-2xl md:text-3xl font-bold text-white mb-4">{entry.data.title}</h1>
        
        <div class="flex flex-wrap items-center gap-4 mb-6 text-xs text-white/60">
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 text-emerald-400/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {formattedDate}
          </div>
          
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span 
                class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
              >
                #{tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
    
    <div 
      class="blog-content prose prose-lg prose-invert prose-emerald max-w-3xl mx-auto rounded-lg glass-effect animate-fade-in p-6"
    >
      <Content />
    </div>
    
    <div class="max-w-3xl mx-auto mt-8 p-4 rounded-lg glass-effect animate-fade-in">
      <h3 class="text-lg font-medium text-white mb-3">Share this article</h3>
      <div class="flex gap-3">
        <a 
          href={`https://twitter.com/intent/tweet?text=${entry.data.title}&url=${encodeURIComponent(`https://farhanahmed.pro/blog/${entry.slug}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 py-1.5 rounded-md bg-[#1DA1F2]/10 text-[#1DA1F2] hover:bg-[#1DA1F2]/20 text-sm transition-colors"
        >
          Twitter
        </a>
        <a 
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://farhanahmed.pro/blog/${entry.slug}`)}&title=${entry.data.title}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 py-1.5 rounded-md bg-[#0077B5]/10 text-[#0077B5] hover:bg-[#0077B5]/20 text-sm transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </div>
    
    <div class="max-w-3xl mx-auto mt-6 flex justify-between animate-fade-in text-sm">
      <a href="/blog" class="text-emerald-400 hover:text-emerald-300 transition-colors group">
        <div class="flex items-center">
          <svg class="w-4 h-4 mr-1 transition-transform duration-300 group-hover:-translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Back to Blog
        </div>
      </a>
      
      <a href="/contact" class="text-emerald-400 hover:text-emerald-300 transition-colors group">
        <div class="flex items-center">
          Have thoughts? Contact me
          <svg class="w-4 h-4 ml-1 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </div>
      </a>
    </div>
  </article>
</Layout>