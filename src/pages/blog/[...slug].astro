---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the blog post for this page
const { entry } = Astro.props;
const { Content } = await entry.render();

// Format date
const formattedDate = format(entry.data.pubDate, "MMMM d, yyyy");
---

<Layout title={`${entry.data.title} | Farhan Ahmed`}>
  <article class="min-h-screen pb-32">
    <div class="mb-10 animate-fade-in">
      <a 
        href="/blog" 
        class="inline-flex items-center text-emerald-400 hover:text-emerald-500 mb-8 group transition-colors"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="h-5 w-5 mr-2 transition-transform group-hover:-translate-x-1" 
          viewBox="0 0 20 20" 
          fill="currentColor"
        >
          <path 
            fill-rule="evenodd" 
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" 
            clip-rule="evenodd"
          />
        </svg>
        <span class="relative">
          Back to Blog
          <span class="absolute left-0 bottom-0 w-full h-[1px] bg-emerald-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
        </span>
      </a>
    </div>
    
    <div class="max-w-4xl mx-auto">
      {entry.data.heroImage && (
        <div class="relative mb-10 rounded-xl overflow-hidden shadow-xl shadow-emerald-500/5 animate-fade-in">
          <img
            src={entry.data.heroImage}
            alt={entry.data.title}
            class="w-full h-96 object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/70"></div>
        </div>
      )}
      
      <div class="mb-10 animate-fade-in">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">{entry.data.title}</h1>
        
        <div class="flex flex-wrap items-center gap-6 mb-10 text-sm">
          <div class="flex items-center text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {formattedDate}
          </div>
          
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span 
                class="px-3 py-1 rounded-full text-xs font-medium text-emerald-400 hover:bg-emerald-500/20 hover:text-emerald-300 transition-colors"
                style={{ backgroundColor: "rgba(16, 185, 129, 0.1)" }}
              >
                #{tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
    
    <div 
      class="blog-content prose prose-lg md:prose-xl prose-invert prose-emerald max-w-4xl mx-auto p-8 rounded-xl glass-effect animate-fade-in hover-card"
      style={{ 
        backgroundColor: "rgba(24, 24, 24, 0.7)",
        borderLeft: '1px solid rgba(16, 185, 129, 0.1)',
        borderTop: '1px solid rgba(16, 185, 129, 0.1)',
      }}
    >
      <Content />
    </div>
    
    <div class="max-w-4xl mx-auto mt-16 p-8 rounded-lg glass-effect animate-fade-in" style={{ backgroundColor: "rgba(24, 24, 24, 0.7)" }}>
      <h3 class="text-xl font-bold text-white mb-4">Share this article</h3>
      <div class="flex gap-4">
        <a 
          href={`https://twitter.com/intent/tweet?text=${entry.data.title}&url=${encodeURIComponent(`https://farhanahmed.pro/blog/${entry.slug}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-lg bg-[#1DA1F2]/10 text-[#1DA1F2] hover:bg-[#1DA1F2]/20 transition-colors"
        >
          Twitter
        </a>
        <a 
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://farhanahmed.pro/blog/${entry.slug}`)}&title=${entry.data.title}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-lg bg-[#0077B5]/10 text-[#0077B5] hover:bg-[#0077B5]/20 transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </div>
    
    <div class="max-w-4xl mx-auto mt-8 flex justify-between animate-fade-in">
      <a href="/blog" class="text-emerald-400 hover:text-emerald-500 transition-colors group">
        <div class="flex items-center">
          <svg class="w-4 h-4 mr-2 transition-transform duration-300 group-hover:-translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Back to Blog
        </div>
      </a>
      
      <a href="/contact" class="text-emerald-400 hover:text-emerald-500 transition-colors group">
        <div class="flex items-center">
          Have thoughts? Contact me
          <svg class="w-4 h-4 ml-2 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </div>
      </a>
    </div>
  </article>
</Layout>

<style>
  /* Custom styles for blog content */
  .blog-content {
    max-width: 100%;
  }
  
  .blog-content :global(h1) {
    @apply text-3xl font-bold text-white mb-6 relative;
    position: relative;
  }
  
  .blog-content :global(h1)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 120px;
    height: 3px;
    background: linear-gradient(to right, var(--accent-500), transparent);
    border-radius: 3px;
  }
  
  .blog-content :global(h2) {
    @apply text-2xl font-bold text-white mt-12 mb-6 relative;
    position: relative;
  }
  
  .blog-content :global(h2)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 80px;
    height: 2px;
    background: linear-gradient(to right, var(--accent-500), transparent);
    border-radius: 2px;
  }
  
  .blog-content :global(h3) {
    @apply text-xl font-bold text-white mt-8 mb-4 text-emerald-400;
  }
  
  .blog-content :global(p) {
    @apply text-white/90 mb-6 leading-relaxed text-lg;
  }
  
  .blog-content :global(ul),
  .blog-content :global(ol) {
    @apply text-white/90 mb-6 pl-6 space-y-2;
  }
  
  .blog-content :global(li) {
    @apply mb-2 hover:text-emerald-300 transition-colors pb-1;
    position: relative;
  }
  
  .blog-content :global(li)::before {
    content: '•';
    @apply text-emerald-500 absolute -left-4;
  }
  
  .blog-content :global(a) {
    @apply text-emerald-400 hover:text-emerald-300 underline decoration-emerald-500/30 hover:decoration-emerald-500 underline-offset-2 transition-all duration-300 font-medium;
  }
  
  .blog-content :global(blockquote) {
    @apply border-l-4 border-emerald-500 pl-6 py-3 my-8 bg-emerald-500/5 rounded-r-lg italic relative;
  }
  
  .blog-content :global(blockquote)::before {
    content: '"';
    @apply text-emerald-500/20 text-7xl absolute -top-5 -left-2 font-serif;
  }
  
  .blog-content :global(code:not(pre code)) {
    @apply bg-emerald-900/30 text-emerald-300 px-1.5 py-0.5 rounded text-sm border border-emerald-500/20;
  }
  
  .blog-content :global(pre) {
    @apply bg-gray-900 p-5 rounded-xl overflow-auto mb-6 border-l-4 border-emerald-500 shadow-lg shadow-black/20;
  }
  
  .blog-content :global(pre code) {
    @apply text-sm font-mono;
  }
  
  .blog-content :global(img) {
    @apply rounded-lg my-8 mx-auto transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in shadow-xl max-w-full;
  }
  
  .blog-content :global(hr) {
    @apply border-0 h-px my-12 bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent;
  }
  
  .blog-content :global(table) {
    @apply w-full border-collapse my-8;
  }
  
  .blog-content :global(th) {
    @apply bg-gray-800 text-emerald-400 p-3 text-left font-semibold border-b border-emerald-500/20;
  }
  
  .blog-content :global(td) {
    @apply p-3 border-b border-gray-700;
  }
  
  .blog-content :global(tr:hover td) {
    @apply bg-emerald-500/5 transition-colors;
  }
</style>