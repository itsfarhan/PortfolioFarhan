---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Get all blog posts
const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort posts by date
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Farhan Ahmed | Blog">
  <div class="min-h-screen pt-8 pb-32">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold text-white mb-4 animate-fade-in relative inline-block">
        Blog
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-emerald-400 to-transparent"></span>
      </h2>
      <p class="text-white/70 max-w-2xl mx-auto animate-fade-in text-sm">
        Thoughts, tutorials and insights on backend development, AWS, and cloud technologies
      </p>
    </div>
    
    <div class="grid grid-cols-1 gap-6">
      {
        sortedPosts.map((post, index) => (
          <a 
            href={`/blog/${post.slug}`}
            class="group glass-effect rounded-lg overflow-hidden hover-card"
            style={{ 
              opacity: 0,
              animation: `fadeIn 0.5s ${index * 0.1}s forwards`,
            }}
          >
            <div class="flex flex-col md:flex-row">
              {post.data.heroImage && (
                <div class="w-full md:w-1/3 h-48 overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              
              <div class="p-5 flex-1 flex flex-col">
                <div class="text-xs text-emerald-400 mb-2">
                  {format(post.data.pubDate, "MMMM d, yyyy")}
                </div>
                
                <h3 class="text-xl font-medium text-white group-hover:text-emerald-400 transition-colors duration-300 mb-2">
                  {post.data.title}
                </h3>
                
                <p class="text-white/70 text-sm mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                
                <div class="mt-auto flex justify-between items-center">
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span 
                        class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                        style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
                      >
                        {tag}
                      </span>
                    ))}
                    {post.data.tags.length > 3 && (
                      <span 
                        class="px-2 py-0.5 rounded-full text-xs text-emerald-300"
                        style={{ backgroundColor: "rgba(16, 185, 129, 0.05)" }}
                      >
                        +{post.data.tags.length - 3}
                      </span>
                    )}
                  </div>
                  
                  <div class="flex items-center text-emerald-400 text-sm font-medium group-hover:translate-x-1 transition-transform duration-300">
                    Read Article
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 ml-1 transition-transform duration-300 group-hover:translate-x-1"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>