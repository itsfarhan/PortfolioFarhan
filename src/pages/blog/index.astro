---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Get all blog posts
const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort posts by date
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Farhan Ahmed | Blog">
  <div class="min-h-screen pb-32">
    <h2 class="text-3xl font-bold text-white mb-12 text-center animate-fade-in">Blog</h2>
    
    <div class="space-y-8">
      {
        sortedPosts.map((post, index) => (
          <a 
            href={`/blog/${post.slug}`}
            class="block p-6 rounded-lg transition-all hover-card glass-effect transform hover:scale-[1.02] duration-300"
            style={{ 
              backgroundColor: "rgba(24, 24, 24, 0.7)",
              borderLeft: '1px solid rgba(16, 185, 129, 0.1)',
              borderTop: '1px solid rgba(16, 185, 129, 0.1)',
              opacity: 0,
              animation: `fadeIn 0.5s ${index * 0.15}s forwards`
            }}
          >
            <div class="flex flex-col md:flex-row gap-6">
              {post.data.heroImage && (
                <div class="md:w-1/3 overflow-hidden rounded-lg">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-48 object-cover rounded-lg transition-transform duration-300 hover:scale-105"
                  />
                </div>
              )}
              <div class={post.data.heroImage ? "md:w-2/3" : "w-full"}>
                <h3 class="text-xl font-semibold text-white mb-2 hover:text-emerald-500 transition-colors">{post.data.title}</h3>
                <p class="text-emerald-400 text-sm mb-3">
                  {format(post.data.pubDate, "MMMM d, yyyy")}
                </p>
                <p class="text-white mb-4">{post.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span 
                      class="px-2 py-1 rounded text-xs text-emerald-400 hover:bg-emerald-500/20 hover:text-emerald-300 transition-colors"
                      style={{ backgroundColor: "var(--light-black-700)" }}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
                <p class="mt-4 text-emerald-500 inline-flex items-center group">
                  Read more
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 ml-1 transition-transform duration-300 group-hover:translate-x-2"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>