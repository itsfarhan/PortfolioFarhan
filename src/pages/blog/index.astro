---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

// Get all blog posts
const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort posts by date
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Farhan Ahmed | Blog">
  <div class="min-h-screen pb-32">
    <div class="mb-16 text-center">
      <h2 class="text-4xl font-bold text-white mb-4 animate-fade-in relative inline-block">
        Blog
        <span class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-transparent"></span>
      </h2>
      <p class="text-gray-300 max-w-2xl mx-auto animate-fade-in">
        Thoughts, tutorials and insights on backend development, AWS, and cloud technologies
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {
        sortedPosts.map((post, index) => (
          <a 
            href={`/blog/${post.slug}`}
            class="group overflow-hidden rounded-xl transition-all duration-500 transform hover:scale-[1.02] hover-card glass-effect"
            style={{ 
              backgroundColor: "rgba(24, 24, 24, 0.7)",
              borderLeft: '1px solid rgba(16, 185, 129, 0.1)',
              borderTop: '1px solid rgba(16, 185, 129, 0.1)',
              opacity: 0,
              animation: `fadeIn 0.5s ${index * 0.15}s forwards`,
              position: 'relative'
            }}
          >
            {post.data.heroImage && (
              <div class="w-full h-56 overflow-hidden">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black opacity-70 group-hover:opacity-50 transition-opacity duration-500"></div>
              </div>
            )}
            
            <div class="p-6 relative">
              <div class="flex items-center mb-3">
                <div class="w-1 h-10 bg-emerald-500 mr-3 rounded group-hover:h-14 transition-all duration-300"></div>
                <div>
                  <span class="text-emerald-400 text-sm font-medium tracking-wide">
                    {format(post.data.pubDate, "MMMM d, yyyy")}
                  </span>
                  <h3 class="text-2xl font-bold text-white group-hover:text-emerald-400 transition-colors duration-300">
                    {post.data.title}
                  </h3>
                </div>
              </div>
              
              <p class="text-white/80 mb-5 line-clamp-3">
                {post.data.description}
              </p>
              
              <div class="flex justify-between items-center">
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span 
                      class="px-2.5 py-1 rounded-full text-xs font-medium text-emerald-400 group-hover:bg-emerald-500/20 transition-colors duration-300"
                      style={{ backgroundColor: "rgba(16, 185, 129, 0.1)" }}
                    >
                      {tag}
                    </span>
                  ))}
                  {post.data.tags.length > 3 && (
                    <span 
                      class="px-2.5 py-1 rounded-full text-xs font-medium text-emerald-400"
                      style={{ backgroundColor: "rgba(16, 185, 129, 0.1)" }}
                    >
                      +{post.data.tags.length - 3}
                    </span>
                  )}
                </div>
                
                <div class="flex items-center text-emerald-500 font-medium group-hover:translate-x-1 transition-transform duration-300">
                  Read Article
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 ml-1 transition-transform duration-300 group-hover:translate-x-1"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>